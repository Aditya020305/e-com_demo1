# Default API URL — points to local backend
REACT_APP_API_URL=http://localhost:5000/api

# ─── NGROK / TUNNEL TESTING ───
# When testing on mobile via ngrok, replace the URL above with your ngrok backend URL:
# REACT_APP_API_URL=https://YOUR-NGROK-ID.ngrok-free.app/api
#
# Then restart the React dev server (npm start) for the change to take effect.
